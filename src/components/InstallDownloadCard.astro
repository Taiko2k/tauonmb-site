---
import { LinkButton } from '@astrojs/starlight/components';

interface Props {
  eyebrow: string;
  metaLabel?: string;
  metaValue?: string;
  primaryHref?: string;
  primaryText?: string;
  secondaryHref?: string;
  secondaryText?: string;
}

const {
  eyebrow,
  metaLabel,
  metaValue,
  primaryHref,
  primaryText,
  secondaryHref,
  secondaryText,
} = Astro.props;
---

<article class="install-download-card">
  <div class="install-download-card__header">
    <span class="install-download-card__eyebrow">{eyebrow}</span>
    {metaValue && (
      <span class="install-download-card__meta">
        {metaLabel && <span class="install-download-card__meta-label">{metaLabel}</span>}
        <code>{metaValue}</code>
      </span>
    )}
  </div>

  <div class="install-download-card__lead">
    <slot />
  </div>

  <div class="install-download-card__actions">
    {primaryHref && primaryText && <LinkButton href={primaryHref}>{primaryText}</LinkButton>}
    {secondaryHref && secondaryText && (
      <LinkButton href={secondaryHref} variant="secondary">{secondaryText}</LinkButton>
    )}
  </div>
</article>

<style>
  .install-download-card {
    display: grid;
    gap: 1rem;
    padding: 1.35rem;
    border-radius: 1rem;
    border: 1px solid color-mix(in srgb, var(--sl-color-accent) 24%, var(--sl-color-gray-5));
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--sl-color-accent) 12%, var(--sl-color-black)) 0%,
        color-mix(in srgb, var(--sl-color-accent-low) 18%, var(--sl-color-black)) 100%
      );
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, white 10%, transparent),
      0 16px 40px color-mix(in srgb, black 28%, transparent);
  }

  .install-download-card__header {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .install-download-card__eyebrow {
    color: var(--sl-color-accent-high);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .install-download-card__meta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.65rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--sl-color-accent) 22%, transparent);
    background: color-mix(in srgb, var(--sl-color-black) 82%, var(--sl-color-accent) 18%);
  }

  .install-download-card__meta-label {
    color: var(--sl-color-gray-2);
    font-size: 0.8rem;
  }

  .install-download-card__meta code {
    color: var(--sl-color-white);
    font-size: 0.85rem;
    font-weight: 700;
  }

  .install-download-card__lead {
    color: var(--sl-color-gray-1);
    line-height: 1.6;
  }

  .install-download-card__lead :global(p) {
    margin: 0;
  }

  .install-download-card__lead :global(p + p),
  .install-download-card__lead :global(p + pre),
  .install-download-card__lead :global(pre + p),
  .install-download-card__lead :global(pre + pre) {
    margin-top: 0.9rem;
  }

  .install-download-card__lead :global(code) {
    color: var(--sl-color-white);
    background: color-mix(in srgb, var(--sl-color-black) 74%, var(--sl-color-accent) 26%);
    border: 1px solid color-mix(in srgb, var(--sl-color-accent) 22%, transparent);
  }

  .install-download-card__lead :global(pre) {
    margin-bottom: 0;
  }

  .install-download-card__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .install-download-card__actions:empty {
    display: none;
  }

  .install-download-card__actions :global(.sl-link-button) {
    margin: 0;
  }

  .install-download-card__actions :global(.sl-link-button.primary) {
    border-color: color-mix(in srgb, var(--sl-color-accent-high) 24%, transparent);
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, white 22%, transparent),
      0 10px 28px color-mix(in srgb, var(--sl-color-accent) 34%, transparent);
  }

  .install-download-card__actions :global(.sl-link-button.secondary) {
    border-color: color-mix(in srgb, var(--sl-color-accent) 18%, var(--sl-color-gray-5));
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--sl-color-black) 78%, var(--sl-color-accent) 10%) 0%,
        color-mix(in srgb, var(--sl-color-black) 92%, var(--sl-color-accent-low) 8%) 100%
      );
    color: var(--sl-color-gray-1);
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, white 10%, transparent),
      0 8px 20px color-mix(in srgb, black 18%, transparent);
  }

  .install-download-card__actions :global(.sl-link-button.secondary:hover) {
    border-color: color-mix(in srgb, var(--sl-color-accent-high) 35%, transparent);
    color: var(--sl-color-white);
  }

  :root[data-theme='light'] .install-download-card {
    border-color: color-mix(in srgb, var(--sl-color-accent) 16%, var(--sl-color-gray-5));
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, white 90%, var(--sl-color-accent-low) 10%) 0%,
        color-mix(in srgb, white 96%, var(--sl-color-accent) 4%) 100%
      );
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, white 92%, transparent),
      0 14px 30px color-mix(in srgb, black 8%, transparent);
  }

  :root[data-theme='light'] .install-download-card__eyebrow {
    color: var(--sl-color-accent-high);
  }

  :root[data-theme='light'] .install-download-card__meta {
    border-color: color-mix(in srgb, var(--sl-color-accent) 18%, var(--sl-color-gray-5));
    background: color-mix(in srgb, white 85%, var(--sl-color-accent-low) 15%);
  }

  :root[data-theme='light'] .install-download-card__meta-label {
    color: var(--sl-color-gray-3);
  }

  :root[data-theme='light'] .install-download-card__meta code,
  :root[data-theme='light'] .install-download-card__lead,
  :root[data-theme='light'] .install-download-card__lead :global(code) {
    color: var(--sl-color-gray-1);
  }

  :root[data-theme='light'] .install-download-card__lead :global(code) {
    background: color-mix(in srgb, white 88%, var(--sl-color-accent-low) 12%);
    border-color: color-mix(in srgb, var(--sl-color-accent) 16%, var(--sl-color-gray-5));
  }

  :root[data-theme='light'] .install-download-card__actions :global(.sl-link-button.primary) {
    border-color: color-mix(in srgb, var(--sl-color-accent) 22%, var(--sl-color-gray-5));
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, white 28%, transparent),
      0 10px 24px color-mix(in srgb, var(--sl-color-accent) 22%, transparent);
  }

  :root[data-theme='light'] .install-download-card__actions :global(.sl-link-button.secondary) {
    border-color: color-mix(in srgb, var(--sl-color-accent) 14%, var(--sl-color-gray-5));
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, white 92%, var(--sl-color-accent-low) 8%) 0%,
        color-mix(in srgb, white 98%, var(--sl-color-accent) 2%) 100%
      );
    color: var(--sl-color-gray-2);
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, white 92%, transparent),
      0 8px 18px color-mix(in srgb, black 6%, transparent);
  }

  :root[data-theme='light'] .install-download-card__actions :global(.sl-link-button.secondary:hover) {
    color: var(--sl-color-gray-1);
  }

  @media (max-width: 40rem) {
    .install-download-card__actions :global(.sl-link-button) {
      width: 100%;
    }
  }
</style>
